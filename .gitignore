# uv
.uv/

# Database
*.db
*.sqlite
*.sqlite3
# Exception: tidus.db is the weekly-sync state (2 MB SQLite, price history
# + revisions). Committed so GitHub Actions weekly-sync workflow has
# persistent state between runs. See .github/workflows/weekly-sync.yml.
!tidus.db

# ML training artifacts — only final inference weights are committed
# (tidus/classification/weights/heads.pt + label_mappings.json,
# and tidus/classification/weights_b/*.joblib). Intermediate training
# checkpoints contain model.safetensors files in the hundreds of MB
# and are not needed for reproducibility — the training scripts
# regenerate them from scratch.
tidus/classification/weights/adapter/
tidus/classification/weights/checkpoints/
tidus/classification/weights_b/checkpoints/
# Lever P1 ablation variants (2026-04-20) — null-result training runs
# reproducible via scripts/p1_step1_baseline.py + p1_step4_postbaseline.py.
# Final production weights remain in weights_b/ (unsuffixed).
tidus/classification/weights_b_p1/
tidus/classification/weights_b_p1_nocw/
tidus/classification/weights_b_ctrl/
tidus/classification/weights_b_ctrl_nocw/

# One-off inspection artifacts (uncertainty sample dumps etc.)
tmp_pack_*.txt

# Local out/ scratch directory — default-ignore everything, then re-include
# the canonical simulation_200_users artifacts (lawyer-review evidence).
/out/*
!/out/simulation_200_users/

# Labeled dataset — distributed separately on Hugging Face Datasets
# (https://huggingface.co/datasets/kensterinvest/tidus-wildchat-classification)
# because a small number of prompts contain real credential patterns from
# upstream WildChat-1M that trip GitHub push-protection. The HF dataset
# is the authoritative public distribution; local clone goes in
# tests/classification/ via `huggingface-cli download …`.
tests/classification/
hf_dataset_staging/

# IDE
.vscode/
.idea/
*.swp
*.swo

