# ── Vendor API Keys ──────────────────────────────────────────────────────────
# Production adapters (8 live)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
DEEPSEEK_API_KEY=...
XAI_API_KEY=...
MOONSHOT_API_KEY=...

# Adapters in progress — set when adapter is ready
# COHERE_API_KEY=...
# GROQ_API_KEY=...
# QWEN_API_KEY=...
# PERPLEXITY_API_KEY=...
# TOGETHER_API_KEY=...

# ── Local Models ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./tidus.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tidus

# ── Redis (optional — for distributed budget counters) ────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Config File Paths ─────────────────────────────────────────────────────────
MODELS_CONFIG_PATH=config/models.yaml
BUDGETS_CONFIG_PATH=config/budgets.yaml
POLICIES_CONFIG_PATH=config/policies.yaml

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
# ENVIRONMENT=development   # disables auth checks and enables CORS wildcard

# CORS origins (production) — comma-separated list of allowed frontend origins
# Leave empty to disable CORS (API-only deployments)
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# ── Email delivery for pricing reports ────────────────────────────────────────
# Option 1 (recommended): Resend — API key only, no password, 3K emails/month free
#   1. Sign up at https://resend.com (free, no credit card)
#   2. Dashboard → API Keys → Create API Key → copy it below
#   3. From address: use "Tidus Reports <onboarding@resend.dev>" until you add a domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# TIDUS_SMTP_FROM=Tidus Reports <onboarding@resend.dev>

# Option 2 (fallback): Any SMTP relay (SendGrid, Mailgun, corporate relay, etc.)
# TIDUS_SMTP_HOST=smtp.sendgrid.net
# TIDUS_SMTP_PORT=587
# TIDUS_SMTP_USER=apikey
# TIDUS_SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxx
# TIDUS_SMTP_FROM=reports@yourdomain.com

# ── Tidus Licensing (for managed/SaaS deployment) ────────────────────────────
# TIDUS_LICENSE_KEY=
# TIDUS_TIER=community
