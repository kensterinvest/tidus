ai-router.z-tidus.com {
    encode gzip zstd

    # Public subscribe API only — full Tidus router/classify/complete stays
    # internal (not proxied here).
    handle /api/v1/subscribe {
        reverse_proxy 127.0.0.1:9000
    }

    handle /healthz {
        reverse_proxy 127.0.0.1:9000
    }

    # Static landing page from the repo working tree
    handle {
        root * /opt/tidus
        try_files {path} /index.html
        file_server
    }
}
